<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>ANIKU — Nonton Anime Tanpa Batas</title>
  <meta name="description" content="Aniku adalah aplikasi streaming anime Android gratis. Tonton ribuan anime sub Indonesia kapan saja, di mana saja." />

  <!-- Tailwind CDN -->
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            ember:   '#E84B1A',
            lava:    '#C0391A',
            coal:    '#0E0A09',
            ash:     '#1A1210',
            smoke:   '#2B1E1A',
            bone:    '#F0EAE6',
            dim:     '#9E8A82',
          },
          fontFamily: {
            display: ['"Bebas Neue"', 'sans-serif'],
            body:    ['"Inter"', 'sans-serif'],
          },
          backgroundImage: {
            'radial-fire': 'radial-gradient(ellipse at 50% 0%, rgba(232,75,26,0.25) 0%, rgba(14,10,9,0) 70%)',
            'ember-glow':  'radial-gradient(circle at 50% 50%, rgba(232,75,26,0.15) 0%, transparent 70%)',
          },
          animation: {
            'pulse-slow': 'pulse 4s cubic-bezier(0.4, 0, 0.6, 1) infinite',
            'float':      'float 6s ease-in-out infinite',
            'glow':       'glow 3s ease-in-out infinite',
          },
          keyframes: {
            float: {
              '0%, 100%': { transform: 'translateY(0px)' },
              '50%':      { transform: 'translateY(-12px)' },
            },
            glow: {
              '0%, 100%': { boxShadow: '0 0 20px rgba(232,75,26,0.4), 0 0 60px rgba(232,75,26,0.1)' },
              '50%':      { boxShadow: '0 0 40px rgba(232,75,26,0.7), 0 0 100px rgba(232,75,26,0.2)' },
            },
          },
        }
      }
    }
  </script>

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />

  <!-- Font Awesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

  <style>
    html { scroll-behavior: smooth; }
    body { background-color: #0E0A09; }

    /* Ember particle effect */
    .particle {
      position: absolute;
      width: 3px;
      height: 3px;
      border-radius: 50%;
      background: #E84B1A;
      animation: rise linear infinite;
      opacity: 0;
    }
    @keyframes rise {
      0%   { transform: translateY(0) scale(1); opacity: 0.8; }
      100% { transform: translateY(-200px) scale(0); opacity: 0; }
    }

    /* Icon glow ring */
    .icon-ring::before {
      content: '';
      position: absolute;
      inset: -6px;
      border-radius: 28%;
      background: conic-gradient(from 0deg, #E84B1A, #FF6B35, #C0391A, #E84B1A);
      animation: spin 8s linear infinite;
      z-index: -1;
      opacity: 0.6;
    }
    @keyframes spin { to { transform: rotate(360deg); } }

    /* Feature card hover */
    .feat-card {
      background: linear-gradient(135deg, rgba(43,30,26,0.8) 0%, rgba(26,18,16,0.9) 100%);
      border: 1px solid rgba(232,75,26,0.15);
      transition: border-color 0.3s, transform 0.3s;
    }
    .feat-card:hover {
      border-color: rgba(232,75,26,0.5);
      transform: translateY(-4px);
    }

    /* Screenshot mockup */
    .phone-frame {
      background: linear-gradient(160deg, #2B1E1A, #1A1210);
      border: 1.5px solid rgba(232,75,26,0.3);
      box-shadow: 0 30px 80px rgba(0,0,0,0.6), 0 0 40px rgba(232,75,26,0.08);
    }

    /* Download button */
    .dl-btn {
      background: linear-gradient(135deg, #E84B1A 0%, #C0391A 100%);
      box-shadow: 0 4px 30px rgba(232,75,26,0.4);
      transition: all 0.25s;
    }
    .dl-btn:hover {
      transform: scale(1.04);
      box-shadow: 0 6px 40px rgba(232,75,26,0.6);
    }
    .dl-btn:active { transform: scale(0.98); }

    /* Section divider */
    .divider {
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(232,75,26,0.4), transparent);
    }

    /* Feature icon box */
    .feat-icon {
      width: 2.25rem;
      height: 2.25rem;
      border-radius: 0.6rem;
      display: flex;
      align-items: center;
      justify-content: center;
      background: rgba(232,75,26,0.12);
      border: 1px solid rgba(232,75,26,0.25);
      color: #E84B1A;
      font-size: 0.9rem;
      flex-shrink: 0;
    }
  </style>
</head>

<body class="font-body text-bone overflow-x-hidden">

  <!-- NAV -->
  <nav class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-6 py-4"
       style="background: linear-gradient(to bottom, rgba(14,10,9,0.95), transparent); backdrop-filter: blur(8px);">
    <div class="flex items-center gap-2">
      <img src="{{ url_for('static', filename='img/icon.png') }}" alt="Aniku" class="w-8 h-8 rounded-xl" />
      <span class="font-display text-2xl tracking-widest text-bone">ANIKU</span>
    </div>
    <a href="#download"
       class="dl-btn text-white font-semibold text-sm px-5 py-2 rounded-full">
      Download APK
    </a>
  </nav>

  <!-- HERO -->
  <section class="relative min-h-screen flex flex-col items-center justify-center px-6 pt-24 pb-16 overflow-hidden">

    <!-- Background radial glow -->
