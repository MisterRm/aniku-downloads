        <img src="{{ url_for('static', filename='img/icon.png') }}"
             alt="Aniku App Icon"
             class="w-full h-full object-cover" />
      </div>
    </div>

    <!-- Headline -->
    <h1 class="font-display text-center text-6xl md:text-8xl lg:text-9xl tracking-widest leading-none mb-4">
      <span class="text-bone">NONTON</span><br />
      <span class="text-ember">ANIME</span><br />
      <span class="text-bone">GRATIS</span>
    </h1>

    <p class="text-center text-dim text-base md:text-lg max-w-sm mt-4 mb-10 leading-relaxed">
      Ribuan judul anime sub Indonesia. Tanpa iklan mengganggu. Langsung di genggamanmu.
    </p>

    <!-- CTA -->
    <a id="download"
       href="https://github.com/RMBLOGG/aniku-app/releases/download/v1.0.0/Aniku.apk"
       class="dl-btn flex items-center gap-3 text-white font-semibold text-lg px-8 py-4 rounded-2xl"
       download>
      <i class="fa-brands fa-android text-xl"></i>
      Download APK &nbsp;·&nbsp; v1.0.0
    </a>

    <p class="text-dim text-xs mt-4">Android 6.0+ &nbsp;·&nbsp; ~15 MB &nbsp;·&nbsp; Gratis</p>

    <!-- Scroll cue -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1 opacity-40 animate-bounce">
      <div class="w-px h-8 bg-ember"></div>
      <i class="fa-solid fa-chevron-down text-ember text-sm"></i>
    </div>
  </section>

  <div class="divider mx-6"></div>

  <!-- FEATURES -->
  <section class="px-6 py-20 max-w-5xl mx-auto">
    <p class="font-display text-center text-4xl md:text-5xl tracking-widest text-bone mb-3">KENAPA ANIKU?</p>
    <p class="text-center text-dim text-sm mb-14">Semua yang kamu butuhkan untuk marathon anime.</p>

    <div class="grid grid-cols-2 md:grid-cols-3 gap-4">

      <div class="feat-card rounded-2xl p-5">
        <div class="text-ember text-2xl mb-3"><i class="fa-solid fa-play"></i></div>
        <h3 class="font-semibold text-bone text-base mb-1">Streaming Langsung</h3>
        <p class="text-dim text-sm leading-relaxed">Tonton episode terbaru tanpa perlu download manual.</p>
      </div>

      <div class="feat-card rounded-2xl p-5">
        <div class="text-ember text-2xl mb-3"><i class="fa-solid fa-bookmark"></i></div>
        <h3 class="font-semibold text-bone text-base mb-1">Bookmark</h3>
        <p class="text-dim text-sm leading-relaxed">Simpan anime favoritmu, lanjutkan kapan saja.</p>
      </div>

      <div class="feat-card rounded-2xl p-5">
        <div class="text-ember text-2xl mb-3"><i class="fa-solid fa-calendar-days"></i></div>
        <h3 class="font-semibold text-bone text-base mb-1">Jadwal Tayang</h3>
        <p class="text-dim text-sm leading-relaxed">Lihat anime yang tayang hari ini sesuai hari rilis.</p>
      </div>

      <div class="feat-card rounded-2xl p-5">
        <div class="text-ember text-2xl mb-3"><i class="fa-solid fa-magnifying-glass"></i></div>
        <h3 class="font-semibold text-bone text-base mb-1">Cari & Filter Genre</h3>
        <p class="text-dim text-sm leading-relaxed">Temukan anime berdasarkan genre atau judul dengan cepat.</p>
      </div>

      <div class="feat-card rounded-2xl p-5">
        <div class="text-ember text-2xl mb-3"><i class="fa-solid fa-user"></i></div>
        <h3 class="font-semibold text-bone text-base mb-1">Akun Gratis</h3>
        <p class="text-dim text-sm leading-relaxed">Daftar dengan email, sinkronisasi bookmark antar perangkat.</p>
      </div>

      <div class="feat-card rounded-2xl p-5">
        <div class="text-ember text-2xl mb-3"><i class="fa-solid fa-circle-half-stroke"></i></div>
        <h3 class="font-semibold text-bone text-base mb-1">Dark & Light Mode</h3>
        <p class="text-dim text-sm leading-relaxed">Tema sesuai selera, mata tetap nyaman marathon malam.</p>
      </div>

    </div>
  </section>

  <div class="divider mx-6"></div>

  <!-- SCREENSHOT PREVIEW SECTION -->
  <section class="px-6 py-20 max-w-5xl mx-auto">
    <p class="font-display text-center text-4xl md:text-5xl tracking-widest text-bone mb-3">TAMPILAN APLIKASI</p>
    <p class="text-center text-dim text-sm mb-16">Langsung dari HP — bukan mockup buatan.</p>

    <div class="flex flex-col md:flex-row items-center gap-12 md:gap-16">

      <!-- Phone screenshot -->
      <div class="shrink-0 flex justify-center">
        <div class="relative">
          <!-- Glow behind phone -->
          <div class="absolute inset-0 rounded-[40px] blur-2xl opacity-30"
               style="background:radial-gradient(ellipse, #E84B1A 0%, transparent 70%);transform:scale(0.85) translateY(10%);"></div>
          <!-- Actual screenshot -->
          <img src="{{ url_for('static', filename='img/ss1.png') }}"
