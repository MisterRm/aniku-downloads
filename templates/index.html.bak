               class="relative w-56 md:w-64 drop-shadow-2xl"
               style="filter: drop-shadow(0 20px 60px rgba(0,0,0,0.8)) drop-shadow(0 0 30px rgba(232,75,26,0.15));" />
        </div>
      </div>

      <!-- Feature highlights dari SS -->
      <div class="flex-1 flex flex-col gap-6">

        <div class="flex items-start gap-4">
          <div class="feat-icon"><i class="fa-solid fa-play"></i></div>
          <div>
            <p class="font-semibold text-bone text-sm mb-1">Hero Banner dengan Judul Featured</p>
            <p class="text-dim text-xs leading-relaxed">Anime pilihan tampil besar di atas, langsung bisa ditonton atau di-bookmark.</p>
          </div>
        </div>

        <div class="flex items-start gap-4">
          <div class="feat-icon"><i class="fa-solid fa-fire"></i></div>
          <div>
            <p class="font-semibold text-bone text-sm mb-1">Sedang Tayang & Terbaru</p>
            <p class="text-dim text-xs leading-relaxed">Kartu anime dengan info episode, rating, dan tombol bookmark langsung dari home.</p>
          </div>
        </div>

        <div class="flex items-start gap-4">
          <div class="feat-icon"><i class="fa-solid fa-compass"></i></div>
          <div>
            <p class="font-semibold text-bone text-sm mb-1">Navigasi 5 Tab</p>
            <p class="text-dim text-xs leading-relaxed">Home · Cari · Eksplor · Bookmark · Jadwal — semua dalam satu bottom bar.</p>
          </div>
        </div>

        <div class="flex items-start gap-4">
          <div class="feat-icon"><i class="fa-solid fa-moon"></i></div>
          <div>
            <p class="font-semibold text-bone text-sm mb-1">Dark Mode Native</p>
            <p class="text-dim text-xs leading-relaxed">UI gelap penuh, nyaman buat marathon tengah malam tanpa silau.</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <div class="divider mx-6"></div>

  <!-- CARA INSTALL -->
  <section class="px-6 py-20 max-w-3xl mx-auto">
    <p class="font-display text-center text-4xl md:text-5xl tracking-widest text-bone mb-12">CARA INSTALL</p>
    <div class="flex flex-col gap-6">

      <div class="flex items-start gap-5">
        <div class="shrink-0 w-10 h-10 rounded-full flex items-center justify-center text-ember font-display text-xl"
             style="background:rgba(232,75,26,0.12);border:1px solid rgba(232,75,26,0.3);">1</div>
        <div>
          <p class="font-semibold text-bone mb-1">Download APK</p>
          <p class="text-dim text-sm">Klik tombol download di halaman ini. File Aniku.apk akan tersimpan otomatis.</p>
        </div>
      </div>

      <div class="flex items-start gap-5">
        <div class="shrink-0 w-10 h-10 rounded-full flex items-center justify-center text-ember font-display text-xl"
             style="background:rgba(232,75,26,0.12);border:1px solid rgba(232,75,26,0.3);">2</div>
        <div>
          <p class="font-semibold text-bone mb-1">Aktifkan "Install dari Sumber Tidak Dikenal"</p>
          <p class="text-dim text-sm">Buka Pengaturan → Keamanan → aktifkan izin install APK dari sumber luar Play Store.</p>
        </div>
      </div>

      <div class="flex items-start gap-5">
        <div class="shrink-0 w-10 h-10 rounded-full flex items-center justify-center text-ember font-display text-xl"
             style="background:rgba(232,75,26,0.12);border:1px solid rgba(232,75,26,0.3);">3</div>
        <div>
          <p class="font-semibold text-bone mb-1">Buka File APK & Install</p>
          <p class="text-dim text-sm">Buka file manager, ketuk Aniku.apk, lalu tap Install. Prosesnya hanya beberapa detik.</p>
        </div>
      </div>

      <div class="flex items-start gap-5">
        <div class="shrink-0 w-10 h-10 rounded-full flex items-center justify-center text-ember font-display text-xl"
             style="background:rgba(232,75,26,0.12);border:1px solid rgba(232,75,26,0.3);">4</div>
        <div>
          <p class="font-semibold text-bone mb-1">Buka & Nikmati!</p>
          <p class="text-dim text-sm">Daftar akun gratis atau langsung browse ribuan anime sub Indonesia.</p>
        </div>
      </div>
    </div>
  </section>

  <div class="divider mx-6"></div>

  <!-- FINAL CTA -->
  <section class="relative px-6 py-24 flex flex-col items-center overflow-hidden">
    <div class="absolute inset-0 bg-ember-glow pointer-events-none"></div>
    <img src="{{ url_for('static', filename='img/icon.png') }}"
         alt="Aniku"
         class="w-20 h-20 rounded-[24%] mb-6 animate-float"
         style="box-shadow:0 0 40px rgba(232,75,26,0.5)" />
    <p class="font-display text-5xl md:text-7xl tracking-widest text-center text-bone mb-3">
      SIAP MARATHON?
    </p>
    <p class="text-dim text-center text-sm mb-10 max-w-xs">
      Download sekarang, gratis selamanya. Tidak perlu kartu kredit, tidak ada iklan.
    </p>
    <a href="https://github.com/RMBLOGG/aniku-app/releases/download/v1.0.0/Aniku.apk"
       class="dl-btn flex items-center gap-3 text-white font-semibold text-xl px-10 py-5 rounded-2xl"
       download>
      <i class="fa-solid fa-download text-lg"></i>
      Download Gratis — v1.0.0
    </a>
    <p class="text-dim text-xs mt-4">Android 6.0+ &nbsp;·&nbsp; APK ~15 MB</p>
  </section>

  <!-- FOOTER -->
  <footer class="px-6 py-8 border-t border-smoke">
    <div class="max-w-5xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4">

      <!-- Brand -->
      <div class="flex items-center gap-2">
        <img src="{{ url_for('static', filename='img/icon.png') }}" class="w-6 h-6 rounded-lg" />
        <span class="font-display tracking-widest text-dim text-sm">ANIKU</span>
      </div>

      <!-- Copyright -->
      <p class="text-dim text-xs text-center">
        &copy; 2024 Aniku. Seluruh hak cipta dilindungi.<br class="md:hidden" />
        <span class="hidden md:inline">&nbsp;·&nbsp;</span>
        Dibuat untuk komunitas anime Indonesia.
      </p>

      <!-- Legal links -->
      <div class="flex items-center gap-4 text-xs text-dim">
        <a href="#" class="hover:text-bone transition-colors">Kebijakan Privasi</a>
        <span class="opacity-30">|</span>
        <a href="#" class="hover:text-bone transition-colors">Syarat Penggunaan</a>
      </div>

    </div>
  </footer>

  <!-- Particle script -->
  <script>
    const container = document.getElementById('particles');
    function spawnParticle() {
      const p = document.createElement('div');
      p.className = 'particle';
      const x = Math.random() * 100;
      const dur = 2 + Math.random() * 3;
      const delay = Math.random() * 2;
      p.style.cssText = `left:${x}%;bottom:10%;animation-duration:${dur}s;animation-delay:${delay}s;opacity:0`;
      container.appendChild(p);
      setTimeout(() => p.remove(), (dur + delay + 0.5) * 1000);
    }
    setInterval(spawnParticle, 200);
  </script>

</body>
</html>
